{
  "TcpClient": {
    "Host": "augustine",
    "Port": 5275,    
    "AddressFamilyPreference": "SystemOrder",
    "ConnectTimeout": "00:00:03",
    "DnsCacheDuration": "00:05:00",
    "FallbackDelay": "00:00:00.250"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System.Net.Sockets": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  }
}